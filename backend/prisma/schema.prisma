generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ShortUrl {
  id            String   @id @default(cuid())
  originalUrl   String
  shortCode     String   @unique
  visitCount    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastVisitedAt DateTime?

  @@index([shortCode])
  @@index([createdAt])
}